<style is:global>
  /* Hide only the search bar when the sidebar is collapsed to maintain a clean mini-sidebar */
  .sidebar-collapse .sidebar-search {
    display: none !important;
  }
</style>

<script is:inline>
	const SIDEBAR_EXPANDED_KEY = globalThis.TechRegistryStorageKeys?.sidebarExpanded || 'techregistry:sidebar-expanded';

	function getSidebarStorage() {
		return globalThis.TechRegistryStorage;
	}

	function normalizePath(path) {
		if (!path) return '/';
		if (path.length > 1 && path.endsWith('/')) {
			return path.slice(0, -1);
		}
		return path;
	}

	function getDirectTreeview(item) {
		return item?.querySelector(':scope > .nav-treeview') ?? null;
	}

	function getExpandableItems(sidebarMenu) {
		return [...sidebarMenu.querySelectorAll('.nav-item')].filter(item => getDirectTreeview(item));
	}

	function ensureMenuIds(sidebarMenu) {
		getExpandableItems(sidebarMenu).forEach((item, index) => {
			if (item.dataset.menuId) return;

			const label = item.querySelector(':scope > .nav-link p')?.childNodes?.[0]?.textContent?.trim()
				|| item.querySelector(':scope > .nav-link')?.textContent?.trim()
				|| `menu-${index}`;

			item.dataset.menuId = label
				.toLowerCase()
				.replace(/[^a-z0-9]+/g, '-')
				.replace(/^-|-$/g, '') || `menu-${index}`;
		});
	}

	function getExpandedMenuIds(sidebarMenu) {
		return getExpandableItems(sidebarMenu)
			.filter(item => item.classList.contains('menu-open'))
			.map(item => item.dataset.menuId)
			.filter(Boolean);
	}

	function saveExpandedMenus(sidebarMenu) {
		getSidebarStorage()?.setJson(SIDEBAR_EXPANDED_KEY, getExpandedMenuIds(sidebarMenu));
	}

	function restoreExpandedMenus(sidebarMenu) {
		const expandedIds = getSidebarStorage()?.getJson(SIDEBAR_EXPANDED_KEY, []) || [];

		getExpandableItems(sidebarMenu).forEach(item => {
			const treeview = getDirectTreeview(item);
			const shouldOpen = expandedIds.includes(item.dataset.menuId);

			item.classList.toggle('menu-open', shouldOpen);
			if (treeview) treeview.style.display = shouldOpen ? 'block' : 'none';
		});
	}

	function applyActiveMenuState(sidebarMenu) {
		const currentPath = normalizePath(globalThis.location?.pathname || '/');
		const links = [...sidebarMenu.querySelectorAll('.nav-link[href]')];

		links.forEach(link => {
			const href = link.getAttribute('href');
			const isRouteLink = href && href !== '#';
			const isActive = isRouteLink && normalizePath(new URL(href, globalThis.location.origin).pathname) === currentPath;

			link.classList.toggle('active', Boolean(isActive));
			if (isActive) link.setAttribute('aria-current', 'page');
			else link.removeAttribute('aria-current');
		});

		const activeLink = links.find(link => link.classList.contains('active'));
		if (!activeLink) return;

		let parent = activeLink.closest('.nav-item');
		while (parent) {
			const treeview = getDirectTreeview(parent);
			if (treeview) {
				parent.classList.add('menu-open');
				treeview.style.display = 'block';
			}
			parent = parent.parentElement?.closest('.nav-item') ?? null;
		}
	}

	function restoreSidebarState(sidebarMenu) {
		restoreExpandedMenus(sidebarMenu);
		applyActiveMenuState(sidebarMenu);
	}

	/**
	 * Sidebar Search Logic for AdminLTE
	 * Filters .nav-item elements based on sidebar input
	 */
	function initSidebarSearch() {
		const searchInput = document.getElementById('sidebar-search-input');
		const sidebarMenu = document.querySelector('.sidebar-menu');

		if (!searchInput || !sidebarMenu) return;
		if (sidebarMenu.dataset.sidebarInitialized === 'true') {
			restoreSidebarState(sidebarMenu);
			return;
		}

		sidebarMenu.dataset.sidebarInitialized = 'true';
		ensureMenuIds(sidebarMenu);
		restoreSidebarState(sidebarMenu);

		sidebarMenu.addEventListener('click', event => {
			const toggleLink = event.target.closest('.nav-item > .nav-link');
			if (!toggleLink || !sidebarMenu.contains(toggleLink)) return;

			const parentItem = toggleLink.closest('.nav-item');
			if (!parentItem || !getDirectTreeview(parentItem)) return;

			globalThis.setTimeout(() => saveExpandedMenus(sidebarMenu), 0);
		});

		sidebarMenu.addEventListener('click', event => {
			const routeLink = event.target.closest('.nav-link[href]');
			if (!routeLink || !sidebarMenu.contains(routeLink)) return;
			if (routeLink.getAttribute('href') === '#') return;

			saveExpandedMenus(sidebarMenu);
		});

		searchInput.addEventListener('input', function (e) {
			const query = e.target.value.toLowerCase().trim();
			const items = sidebarMenu.querySelectorAll('.nav-item');
			const headers = sidebarMenu.querySelectorAll('.nav-header');

			if (query.length > 0) {
				// 1. Hide all items and headers initially
				items.forEach(item => {
					item.classList.add('d-none');
					item.classList.remove('menu-open');
					const tv = item.querySelector(':scope > .nav-treeview');
					if (tv) tv.style.display = 'none';
				});
				headers.forEach(h => h.classList.add('d-none'));

				// 2. Scan links for matches
				const links = sidebarMenu.querySelectorAll('.nav-link');
				links.forEach(link => {
					const text = link.innerText.toLowerCase();
					if (text.includes(query)) {
						const item = link.closest('.nav-item');
						if (!item) return;

						// Show the matching item
						item.classList.remove('d-none');

						// Walk up the DOM to show and expand all parent ancestors
						let parent = item.parentElement.closest('.nav-item');
						while (parent) {
							parent.classList.remove('d-none');
							parent.classList.add('menu-open');
							const tv = parent.querySelector(':scope > .nav-treeview');
							if (tv) tv.style.display = 'block';
							parent = parent.parentElement.closest('.nav-item');
						}
					}
				});

				// 3. Restore visibility to section headers if they have visible children
				headers.forEach(header => {
					let next = header.nextElementSibling;
					while (next && !next.classList.contains('nav-header')) {
						if (next.classList.contains('nav-item') && !next.classList.contains('d-none')) {
							header.classList.remove('d-none');
							break;
						}
						next = next.nextElementSibling;
					}
				});
			} else {
				// 4. Reset: Show everything and restore persisted expansion state
				headers.forEach(h => h.classList.remove('d-none'));
				items.forEach(item => {
					item.classList.remove('d-none');
					const tv = item.querySelector(':scope > .nav-treeview');
					if (tv) tv.style.display = 'none';
				});
				restoreSidebarState(sidebarMenu);
			}
		});
	}

	// Initialize logic and handle Astro transitions
	document.addEventListener('astro:page-load', initSidebarSearch);
	if (document.readyState !== 'loading') initSidebarSearch();
	else document.addEventListener('DOMContentLoaded', initSidebarSearch);
</script>
