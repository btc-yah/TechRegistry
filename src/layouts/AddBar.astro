---
const recentActions = [
	{ label: "JSON to XML", time: "2 mins ago" },
	{ label: "Minified CSS", time: "9 mins ago" },
	{ label: "Decoded JWT", time: "18 mins ago" },
];

---

<aside class="content-ad-rail utility-rail">
	<div class="content-rail-card">
		<div class="content-rail-card-header">
			<span class="content-rail-label">Advertisement</span>
			<h3 class="content-rail-title">Featured Space</h3>
		</div>
		<div class="content-ad-slot content-ad-slot-lg">
			<div class="placeholder-glow">
				<span class="placeholder col-12 rounded"></span>
			</div>
		</div>
	</div>

	<div class="content-rail-card utility-developer-card">
		<div class="content-rail-card-header">
			<span class="content-rail-label">Developer</span>
			<h3 class="content-rail-title">Browser Snapshot</h3>
		</div>
		<div class="utility-metadata">
			<div class="utility-metadata-row">
				<span>Status</span>
				<strong class="text-success">
					<i class="fa-solid fa-circle utility-online-dot"></i>
					System Online
				</strong>
			</div>
			<div class="utility-metadata-row">
				<span>Execution Time</span>
				<strong id="utilityExecutionTime">12ms</strong>
			</div>
			<div class="utility-metadata-row">
				<span>User Agent</span>
				<div class="utility-copy-group">
					<strong id="utilityUserAgent">Detecting...</strong>
				</div>
			</div>
			<div class="utility-metadata-row">
				<span>Language</span>
				<strong id="utilityLanguage">Detecting...</strong>
			</div>
			<div class="utility-metadata-row">
				<span>Platform</span>
				<strong id="utilityPlatform">Detecting...</strong>
			</div>
			<div class="utility-metadata-row">
				<span>Cookies</span>
				<strong id="utilityCookiesEnabled">Detecting...</strong>
			</div>
			<div class="utility-metadata-row">
				<span>CPU Cores</span>
				<strong id="utilityCpuCores">Detecting...</strong>
			</div>
			<div class="utility-metadata-row">
				<span>Memory</span>
				<strong id="utilityMemory">Detecting...</strong>
			</div>
			<div class="utility-metadata-row">
				<span>PDF Viewer</span>
				<strong id="utilityPdfViewer">Detecting...</strong>
			</div>
			<div class="utility-metadata-row">
				<span>Available Screen</span>
				<strong id="utilityAvailableScreen">Detecting...</strong>
			</div>
			<div class="utility-metadata-row">
				<span>Color Depth</span>
				<strong id="utilityColorDepth">Detecting...</strong>
			</div>
		</div>
	</div>

	<div class="content-rail-card utility-workspace-card">
		<div class="content-rail-card-header">
			<span class="content-rail-label">Workspace</span>
			<h3 class="content-rail-title">Recent Actions</h3>
		</div>
		<div class="utility-workspace-body">
			<div class="utility-section-label">Recent</div>
			<ul class="list-group list-group-flush utility-list" id="recentActionsList">
				{
					recentActions.map((action) => (
						<li class="list-group-item">
							<div>
								<strong>{action.label}</strong>
								<small>{action.time}</small>
							</div>
							<button class="btn btn-link btn-sm px-0 text-decoration-none">Open</button>
						</li>
					))
				}
			</ul>
			<div class="utility-actions-row">
				<button id="clearHistoryBtn" class="btn btn-outline-secondary btn-sm">Clear History</button>
				<span class="utility-status-inline">Stored locally</span>
			</div>
		</div>
	</div>

	<div class="content-rail-card">
		<div class="content-rail-card-header">
			<span class="content-rail-label">Advertisement</span>
			<h3 class="content-rail-title">Sponsored Space</h3>
		</div>
		<div class="content-ad-slot">
			<div class="placeholder-glow">
				<span class="placeholder col-12 rounded"></span>
			</div>
		</div>
	</div>
</aside>

<script is:inline>
	const updateUtilitySidebar = () => {
		const availableScreen = document.getElementById("utilityAvailableScreen");
		const colorDepth = document.getElementById("utilityColorDepth");
		const userAgent = document.getElementById("utilityUserAgent");
		const language = document.getElementById("utilityLanguage");
		const platform = document.getElementById("utilityPlatform");
		const cookiesEnabled = document.getElementById("utilityCookiesEnabled");
		const cpuCores = document.getElementById("utilityCpuCores");
		const memory = document.getElementById("utilityMemory");
		const pdfViewer = document.getElementById("utilityPdfViewer");
		const executionTime = document.getElementById("utilityExecutionTime");
		const clearHistoryBtn = document.getElementById("clearHistoryBtn");
		const recentActionsList = document.getElementById("recentActionsList");

		if (availableScreen) {
			availableScreen.textContent = `${screen.availWidth} x ${screen.availHeight}`;
		}

		if (colorDepth) {
			colorDepth.textContent = `${screen.colorDepth}-bit`;
		}

		if (userAgent) {
			userAgent.textContent = navigator.userAgent.replace(/\s+/g, " ").slice(0, 42) + "...";
		}

		if (language) {
			language.textContent = navigator.language || "Unavailable";
		}

		if (platform) {
			platform.textContent = navigator.platform || "Unavailable";
		}

		if (cookiesEnabled) {
			cookiesEnabled.textContent = navigator.cookieEnabled ? "Enabled" : "Disabled";
		}

		if (cpuCores) {
			cpuCores.textContent = navigator.hardwareConcurrency
				? `${navigator.hardwareConcurrency} logical cores`
				: "Unavailable";
		}

		if (memory) {
			memory.textContent = navigator.deviceMemory
				? `${navigator.deviceMemory} GB`
				: "Unavailable";
		}

		if (pdfViewer) {
			pdfViewer.textContent = navigator.pdfViewerEnabled ? "Enabled" : "Unavailable";
		}

		if (executionTime && typeof performance !== "undefined") {
			executionTime.textContent = `${Math.round(performance.now())}ms`;
		}

		if (clearHistoryBtn && recentActionsList) {
			clearHistoryBtn.addEventListener("click", () => {
				recentActionsList.innerHTML =
					'<li class="list-group-item"><div><strong>History cleared</strong><small>Your recent actions were removed from this session.</small></div><span class="utility-status-inline">Private</span></li>';
			});
		}
	};

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", updateUtilitySidebar, { once: true });
	} else {
		updateUtilitySidebar();
	}
</script>

<style>
	.utility-rail {
		display: grid;
		gap: 1rem;
	}

	.utility-rail .content-rail-card {
		border: 1px solid rgba(255, 255, 255, 0.08);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01)),
			var(--bs-body-bg);
		border-radius: 1rem;
		box-shadow: 0 1rem 2.5rem rgba(0, 0, 0, 0.18);
	}

	.utility-rail .content-rail-card-header {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		margin-bottom: 1rem;
	}

	.utility-rail .content-rail-label {
		font-size: 0.72rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--bs-secondary-color);
	}

	.utility-rail .content-rail-title {
		margin: 0;
		font-size: 1rem;
	}

	.utility-list,
	.utility-link-list {
		gap: 0.25rem;
	}

	.utility-list .list-group-item,
	.utility-link-list .list-group-item {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 0.55rem 0;
		background: transparent;
		border-color: rgba(255, 255, 255, 0.08);
		color: inherit;
	}

	.utility-list .list-group-item small,
	.utility-changelog p,
	.utility-upload-zone small {
		display: block;
		color: var(--bs-secondary-color);
	}

	.utility-actions-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-top: 0.9rem;
		gap: 0.75rem;
	}

	.utility-status-inline {
		font-size: 0.78rem;
		color: var(--bs-secondary-color);
	}

	.utility-section-label {
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--bs-secondary-color);
	}

	.utility-list-icon {
		width: 1.5rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--bs-info);
	}

	.utility-metadata {
		display: grid;
		gap: 0.5rem;
		max-height: 16rem;
		overflow-y: auto;
		padding-right: 0.25rem;
	}

	.utility-metadata-row {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.6rem;
		font-size: 0.78rem;
	}

	.utility-metadata-row span {
		color: var(--bs-secondary-color);
	}

	.utility-metadata-row strong {
		max-width: 60%;
		text-align: right;
		word-break: break-word;
	}

	.utility-copy-group {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.25rem;
		max-width: 60%;
	}

	.utility-copy-group strong {
		max-width: 100%;
	}

	.utility-online-dot {
		font-size: 0.55rem;
		margin-right: 0.35rem;
		vertical-align: middle;
	}

	.utility-developer-card .content-rail-card-header {
		margin-bottom: 0.55rem;
	}

	.utility-workspace-card .content-rail-card-header {
		margin-bottom: 0.55rem;
	}

	.utility-workspace-body {
		max-height: 9rem;
		overflow-y: auto;
		padding-right: 0.25rem;
	}

	.content-ad-slot {
		min-height: 18vh;
	}

	.content-ad-slot-lg {
		min-height: 24vh;
	}

	.content-ad-slot .placeholder {
		min-height: 16vh;
	}

	.content-ad-slot-lg .placeholder {
		min-height: 22vh;
	}
</style>
