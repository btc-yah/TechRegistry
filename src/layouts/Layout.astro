---
import Header from "./Header.astro";
import Sidebar from "./Sidebar.astro";
import Footer from "./Footer.astro";

interface Props {
	title?: string;
	description?: string;
}

const { title = "TechRegistry", description } = Astro.props;
const pageName = title.replace(/\s*\|\s*TechRegistry\s*$/i, "").trim() || "TechRegistry";
const pageDescription = description ?? `${pageName} is a free online TechRegistry tool for developers, testers, and technical teams. Use it to format, convert, validate, generate, compare, or inspect data quickly in a clean browser-based workspace.`;
---

<!doctype html>
<html lang="en" data-bs-theme="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={pageDescription} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={pageDescription} />
		<link rel="stylesheet" href="/css/adminlte.css" />
		<link rel="stylesheet" href="/css/layouts/site.css" />
		<link rel="stylesheet" href="/css/layouts/sidebar.css" />
		<link
			rel="stylesheet"
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
		/>
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
		/>
		<script src="https://code.jquery.com/jquery-3.7.1.min.js" is:inline></script>
		<script src="/js/storage-keys.js" is:inline></script>
		<script src="/js/storage-utils.js" is:inline></script>
		<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
		<slot name="head" />
	</head>

	<body class="layout-fixed sidebar-expand-lg sidebar-mini bg-body-tertiary app-loaded sidebar-open">
		<div class="app-wrapper">
			<Header />
			<Sidebar />

			<main class="app-main">
				<slot />
			</main>

			<Footer />
		</div>

		<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1200;">
			<div id="app-toast" class="toast border-0" role="status" aria-live="polite" aria-atomic="true">
				<div id="app-toast-body" class="toast-body rounded shadow-sm bg-body-secondary text-body"></div>
			</div>
		</div>

		<script src="/js/overlayscrollbars.browser.es6.min.js" is:inline></script>
		<script src="/js/popper.min.js" is:inline></script>
		<script src="/js/bootstrap.min.js" is:inline></script>
		<script src="/js/adminlte.js" is:inline></script>
		<script src="/js/Sortable.min.js" is:inline></script>
		<script src="/js/apexcharts.min.js" is:inline></script>
		<script src="https://cdn.jsdelivr.net/npm/clipboard@2.0.11/dist/clipboard.min.js" is:inline></script>
		<script src="/js/site.js" is:inline></script>

		<script is:inline>
			const sidebarWrapper = document.querySelector(".sidebar-wrapper");
			const overlay = globalThis.OverlayScrollbarsGlobal?.OverlayScrollbars;
			const toastElement = document.querySelector("#app-toast");
			const toastBody = document.querySelector("#app-toast-body");

			if (sidebarWrapper && overlay) {
				overlay(sidebarWrapper, {
					scrollbars: {
						theme: "os-theme-light",
						autoHide: "leave",
						clickScroll: true,
					},
				});
			}

			globalThis.appToast = (message, kind = "neutral") => {
				if (!toastElement || !toastBody || !globalThis.bootstrap?.Toast) return;
				toastBody.textContent = message;
				toastBody.className = "toast-body rounded shadow-sm text-white";

				if (kind === "error") {
					toastBody.classList.add("bg-danger");
				} else if (kind === "success") {
					toastBody.classList.add("bg-success");
				} else {
					toastBody.classList.add("bg-secondary");
				}

				globalThis.bootstrap.Toast.getOrCreateInstance(toastElement, {
					delay: 2400,
				}).show();
			};
		</script>
	</body>
</html>
