---
import Layout from "../../layouts/Layout.astro";
import Content from "../../layouts/Content.astro";
const pageScript = "/js/pages/validators/json.js";
---
<Layout title="Validate JSON | TechRegistry"><Content title="Validate JSON" titleTag="Validator" starCount="6.0k stars" usageCount="10.8k uses today" version="v2.7.1" statusText="All Systems Operational" freeLabel="100% Free" privacyLabel="Client-Side Only" poweredBy="JSON.parse" poweredByLink="https://developer.mozilla.org/docs/Web/JavaScript/Reference/Global_Objects/JSON/parse" breadcrumbs={[{ label: "Home", href: "/" }, { label: "Validate JSON" }]}><div class="tool-page-shell" id="tool-page-root"><div class="card"><div class="card-body"><div class="tool-toolbar"><button id="tool-load-sample" class="btn btn-outline-light btn-sm" type="button">Load Sample</button><button id="tool-clear" class="btn btn-outline-secondary btn-sm" type="button">Clear</button><button id="tool-run" class="btn btn-primary btn-sm" type="button">Validate JSON</button></div><div id="tool-status" class="tool-status mt-3">Ready.</div><div class="tool-editors mt-3"><div><div class="tool-label-row"><label for="tool-input" class="form-label mb-0">JSON Input</label><span class="text-body-secondary">Paste JSON object or array</span></div><textarea id="tool-input" class="form-control tool-code-input js-clipboard-source"></textarea></div><div><div class="tool-label-row"><label class="form-label mb-0">Validation Output</label><span class="text-body-secondary">Formatted valid JSON appears here</span></div><pre id="tool-output" class="tool-code-output"></pre></div></div></div></div><div class="card tool-details-card"><div class="card-header"><h3 class="card-title">About This JSON Validator</h3></div><div class="card-body"><p>This JSON validator helps confirm whether payloads, config blocks, fixtures, and API samples are valid before use in code or tests.</p><p>It is useful when debugging malformed payloads, copied request bodies, and integration data.</p><ul class="tool-detail-list"><li>Validates JSON directly in the browser.</li><li>Shows formatted output for valid content.</li><li>Good for API and config debugging.</li></ul></div></div></div></Content></Layout><script type="module" src={pageScript}></script>
