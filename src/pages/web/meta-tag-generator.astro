---
import Layout from "../../layouts/Layout.astro";
import Content from "../../layouts/Content.astro";
const pageScript = "/js/pages/web/meta-tag-generator.js";
---
<Layout title="Meta Tag Generator | TechRegistry"><Content title="Meta Tag Generator" titleTag="Web" starCount="5.0k stars" usageCount="7.8k uses today" version="v2.7.1" statusText="All Systems Operational" freeLabel="100% Free" privacyLabel="Client-Side Only" poweredBy="browser-side JS" breadcrumbs={[{ label: "Home", href: "/" }, { label: "Meta Tag Generator" }]}><div class="tool-page-shell" id="tool-page-root"><div class="card"><div class="card-body"><div class="tool-toolbar"><button id="tool-load-sample" class="btn btn-outline-light btn-sm" type="button">Load Sample</button><button id="tool-clear" class="btn btn-outline-secondary btn-sm" type="button">Clear</button><button id="tool-run" class="btn btn-primary btn-sm" type="button">Generate Tags</button></div><div class="tool-field-grid mt-3 mb-3"><div><label class="form-label" for="meta-title">Title</label><input id="meta-title" class="form-control" data-tool-field="title" /></div><div><label class="form-label" for="meta-site">Site Name</label><input id="meta-site" class="form-control" data-tool-field="siteName" /></div><div><label class="form-label" for="meta-url">URL</label><input id="meta-url" class="form-control" data-tool-field="url" /></div><div><label class="form-label" for="meta-image">Image URL</label><input id="meta-image" class="form-control" data-tool-field="image" /></div><div class="w-100"><label class="form-label" for="meta-description">Description</label><textarea id="meta-description" class="form-control js-clipboard-source" data-tool-field="description"></textarea></div></div><div id="tool-status" class="tool-status">Ready.</div><div class="mt-3"><div class="tool-label-row"><label class="form-label mb-0">Meta Tags</label><span class="text-body-secondary">Generated tags appear here</span></div><pre id="tool-output" class="tool-code-output"></pre></div><div id="tool-detail-panel" hidden class="mt-3"><div class="tool-label-row"><label class="form-label mb-0">Preview Card</label><span class="text-body-secondary">Social preview snapshot</span></div><div id="tool-detail-output" class="tool-detail-output"></div></div></div></div><div class="card tool-details-card"><div class="card-header"><h3 class="card-title">About This Meta Tag Generator</h3></div><div class="card-body"><p>This meta tag generator helps build page title, description, canonical, Open Graph, and Twitter-friendly tags for landing pages, docs, and product pages.</p><p>It is useful for SEO setup, share previews, and content publishing workflows.</p><ul class="tool-detail-list"><li>Generates common SEO and social tags.</li><li>Includes a visual preview card.</li><li>Useful for landing pages and documentation sites.</li></ul></div></div></div></Content></Layout><script type="module" src={pageScript}></script>
