---
import Layout from "../../layouts/Layout.astro";
import Content from "../../layouts/Content.astro";
const pageScript = "/js/pages/web/open-graph-preview.js";
---
<Layout title="Open Graph Preview | TechRegistry"><Content title="Open Graph Preview" titleTag="Web" starCount="4.8k stars" usageCount="7.1k uses today" version="v2.7.1" statusText="All Systems Operational" freeLabel="100% Free" privacyLabel="Client-Side Only" poweredBy="browser-side JS" breadcrumbs={[{ label: "Home", href: "/" }, { label: "Open Graph Preview" }]}><div class="tool-page-shell" id="tool-page-root"><div class="card"><div class="card-body"><div class="tool-toolbar"><button id="tool-load-sample" class="btn btn-outline-light btn-sm" type="button">Load Sample</button><button id="tool-clear" class="btn btn-outline-secondary btn-sm" type="button">Clear</button><button id="tool-run" class="btn btn-primary btn-sm" type="button">Generate Preview</button></div><div class="tool-field-grid mt-3 mb-3"><div><label class="form-label" for="og-title">Title</label><input id="og-title" class="form-control" data-tool-field="title" /></div><div><label class="form-label" for="og-site">Site Name</label><input id="og-site" class="form-control" data-tool-field="siteName" /></div><div><label class="form-label" for="og-url">URL</label><input id="og-url" class="form-control" data-tool-field="url" /></div><div><label class="form-label" for="og-image">Image URL</label><input id="og-image" class="form-control" data-tool-field="image" /></div><div class="w-100"><label class="form-label" for="og-description">Description</label><textarea id="og-description" class="form-control js-clipboard-source" data-tool-field="description"></textarea></div></div><div id="tool-status" class="tool-status">Ready.</div><div class="mt-3"><div class="tool-label-row"><label class="form-label mb-0">Open Graph Tags</label><span class="text-body-secondary">Generated tags appear here</span></div><pre id="tool-output" class="tool-code-output"></pre></div><div id="tool-detail-panel" hidden class="mt-3"><div class="tool-label-row"><label class="form-label mb-0">Preview Card</label><span class="text-body-secondary">Visual preview snapshot</span></div><div id="tool-detail-output" class="tool-detail-output"></div></div></div></div><div class="card tool-details-card"><div class="card-header"><h3 class="card-title">About This Open Graph Preview Tool</h3></div><div class="card-body"><p>This Open Graph preview tool helps shape social share cards for links posted on chat apps, social networks, and documentation portals.</p><p>It is useful for previewing how title, description, site name, and image work together before publishing.</p><ul class="tool-detail-list"><li>Generates Open Graph tags from one form.</li><li>Shows a card-style preview.</li><li>Useful for social sharing and page polish.</li></ul></div></div></div></Content></Layout><script type="module" src={pageScript}></script>
