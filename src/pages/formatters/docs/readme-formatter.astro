---
import Layout from "../../../layouts/Layout.astro";
import Content from "../../../layouts/Content.astro";

const pageScript = "/js/pages/docs/readme-formatter.js";

const sampleInput = `#   techregistry

A browser-first toolbox for compare, conversion and formatting.

##features
-JSON tools
-compare pages
-converter pages

## usage
1. open a tool
2. paste content
3. copy the result

###notes
Works fully in browser.`;

const sampleOutput = `# techregistry

A browser-first toolbox for compare, conversion and formatting.

## features

- JSON tools
- compare pages
- converter pages

## usage

1. open a tool
2. paste content
3. copy the result

### notes

Works fully in browser.`;
---

<Layout title="README Formatter | TechRegistry">
	<Content
		title="README Formatter"
		titleTag="Docs"
		starCount="4.5k stars"
		usageCount="6.9k uses today"
		version="v2.7.1"
		statusText="Tests Passing"
		freeLabel="100% Free"
		privacyLabel="Client-Side Only"
		poweredBy="JavaScript"
		poweredByLink="https://developer.mozilla.org/en-US/docs/Web/JavaScript"
		breadcrumbs={[
			{ label: "Home", href: "/" },
			{ label: "README Formatter" },
		]}
	>
		<div class="tool-page-shell">
			<div class="card">
				<div class="card-body">
					<div class="tool-toolbar">
						<button
							id="load-sample"
							class="btn btn-outline-light btn-sm"
							type="button">Load Sample</button
						>
						<button
							id="clear-input"
							class="btn btn-outline-secondary btn-sm"
							type="button">Clear</button
						>
						<button
							id="format-readme"
							class="btn btn-primary btn-sm"
							type="button">Format README</button
						>
						<button
							id="copy-output"
							class="btn btn-outline-info btn-sm tool-toolbar-copy"
							type="button">Copy Output</button
						>
					</div>

					<div class="tool-field-grid mt-3 mb-3">
						<div class="form-check">
							<input
								class="form-check-input"
								type="checkbox"
								id="normalize-headings"
								checked
							/>
							<label
								class="form-check-label"
								for="normalize-headings"
								>Normalize markdown headings</label
							>
						</div>
						<div class="form-check">
							<input
								class="form-check-input"
								type="checkbox"
								id="normalize-lists"
								checked
							/>
							<label
								class="form-check-label"
								for="normalize-lists"
								>Normalize bullets and numbered lists</label
							>
						</div>
					</div>

					<div class="tool-editors">
						<div>
							<div class="tool-label-row">
								<label for="docs-input" class="form-label mb-0"
									>README Input</label
								>
								<span class="text-body-secondary"
									>Paste rough markdown or README text</span
								>
							</div>
							<textarea
								id="docs-input"
								class="form-control tool-code-input js-clipboard-source"
								>{sampleInput}</textarea
							>
						</div>
						<div>
							<div class="tool-label-row">
								<label class="form-label mb-0"
									>README Preview</label
								>
								<span class="text-body-secondary"
									>Rendered markdown view</span
								>
							</div>
							<div
								id="docs-output"
								class="tool-code-output border rounded p-3 bg-body-tertiary js-clipboard-source"
								style="overflow-y: auto;"
							>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="card tool-details-card">
				<div class="card-header">
					<h3 class="card-title">About This README Formatter</h3>
				</div>
				<div class="card-body">
					<p>
						This README formatter is useful when project docs become
						inconsistent from fast edits, copied sections, or mixed
						markdown styles across contributors.
					</p>
					<p>
						It helps clean spacing, heading structure, and list
						formatting before a README goes into review, publishing,
						or a release update.
					</p>
					<ul class="tool-detail-list">
						<li>
							Normalizes rough markdown into cleaner README
							structure.
						</li>
						<li>
							Helps make headings, bullets, and spacing more
							consistent.
						</li>
						<li>
							Good for open-source docs, internal repos, and quick
							polish passes.
						</li>
					</ul>
				</div>
			</div>
		</div>
	</Content>
</Layout>

<div
	hidden
	data-readme-formatter-config
	data-sample-input={encodeURIComponent(sampleInput)}
	data-sample-output={encodeURIComponent(sampleOutput)}
>
</div>
<script type="module" src={pageScript}></script>
