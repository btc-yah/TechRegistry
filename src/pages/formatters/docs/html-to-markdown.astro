---
import Layout from "../../../layouts/Layout.astro";
import Content from "../../../layouts/Content.astro";

const pageScript = "/js/pages/docs/html-to-markdown.js";

const sampleInput = `<article><h1>TechRegistry Notes</h1><p>Use the <strong>compare</strong> tools to review changes and the <a href="/converters/json-yaml">converter</a> pages to move between formats.</p><ul><li>Fast setup</li><li>Client-side only</li><li>Built for daily dev work</li></ul></article>`;
const sampleOutput = `# TechRegistry Notes

Use the **compare** tools to review changes and the [converter](/converters/json-yaml) pages to move between formats.

- Fast setup
- Client-side only
- Built for daily dev work`;
---

<Layout title="HTML to Markdown | TechRegistry">
	<Content
		title="HTML to Markdown"
		titleTag="Docs"
		starCount="4.8k stars"
		usageCount="7.4k uses today"
		version="v2.7.1"
		statusText="All Systems Operational"
		freeLabel="100% Free"
		privacyLabel="Client-Side Only"
		poweredBy="turndown"
		poweredByLink="https://github.com/mixmark-io/turndown"
		breadcrumbs={[
			{ label: "Home", href: "/" },
			{ label: "HTML to Markdown" },
		]}
	>
		<div class="tool-page-shell">
			<div class="card">
				<div class="card-body">
					<div class="tool-toolbar">
						<button
							id="load-sample"
							class="btn btn-outline-light btn-sm"
							type="button">Load Sample</button
						>
						<button
							id="clear-input"
							class="btn btn-outline-secondary btn-sm"
							type="button">Clear</button
						>
						<button
							id="convert-markdown"
							class="btn btn-primary btn-sm"
							type="button">Convert</button
						>
						<button
							id="copy-output"
							class="btn btn-outline-info btn-sm tool-toolbar-copy"
							type="button">Copy Output</button
						>
					</div>

					<div class="tool-field-grid mt-3 mb-3">
						<div>
							<label for="heading-style" class="form-label"
								>Heading Style</label
							>
							<select id="heading-style" class="form-select">
								<option value="atx">ATX (#)</option>
								<option value="setext">Setext</option>
							</select>
						</div>
						<div>
							<label for="bullet-marker" class="form-label"
								>Bullet Marker</label
							>
							<select id="bullet-marker" class="form-select">
								<option value="-">Dash</option>
								<option value="*">Asterisk</option>
							</select>
						</div>
					</div>

					<div class="tool-editors">
						<div>
							<div class="tool-label-row">
								<label for="docs-input" class="form-label mb-0"
									>Input HTML</label
								>
								<span class="text-body-secondary"
									>Paste article, snippet, or docs HTML</span
								>
							</div>
							<textarea
								id="docs-input"
								class="form-control tool-code-input js-clipboard-source"
								>{sampleInput}</textarea
							>
						</div>
						<div>
							<div class="tool-label-row">
								<label class="form-label mb-0"
									>Markdown Output</label
								>
								<span class="text-body-secondary"
									>Clean markdown appears here</span
								>
							</div>
							<pre
								id="docs-output"
								class="tool-code-output">{sampleOutput}</pre>
						</div>
					</div>
				</div>
			</div>

			<div class="card tool-details-card">
				<div class="card-header">
					<h3 class="card-title">About This HTML to Markdown Tool</h3>
				</div>
				<div class="card-body">
					<p>
						This HTML to Markdown converter is built for
						documentation cleanup, README migration, CMS exports,
						and content publishing workflows where source markup
						needs a markdown version.
					</p>
					<p>
						It is useful for blog excerpts, knowledge base content,
						article imports, release notes, and snippets copied from
						rendered pages or editors.
					</p>
					<ul class="tool-detail-list">
						<li>
							Converts headings, links, emphasis, and lists into
							markdown.
						</li>
						<li>
							Useful for docs migration and README preparation.
						</li>
						<li>
							Keeps conversion in the browser for quick safe
							edits.
						</li>
					</ul>
				</div>
			</div>
		</div>
	</Content>
</Layout>

<div
	hidden
	data-html-markdown-config
	data-sample-input={encodeURIComponent(sampleInput)}
	data-sample-output={encodeURIComponent(sampleOutput)}
>
</div>
<script type="module" src={pageScript}></script>
