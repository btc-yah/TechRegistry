---
import Layout from '../layouts/Layout.astro';
import Content from '../layouts/Content.astro';
import AnalogClock from '../pages/AnalogClock.astro';

---

<Layout title="Dashboard | TechRegistry">
	<Content
		title="Personal Dashboard"
		titleTag="Daily Overview"
		version="v2.8.0"
		statusText="All Systems Operational"
		privacyLabel="Client-Side Only"
		poweredBy="Open Source APIs"
		fullWidth={true}
		breadcrumbs={[{ label: "Home" }]}
	>
		<div class="container-fluid p-0">
			<div class="row g-4">
				<!-- Weather Widget -->
				<div class="col-md-6 col-xl-4">
					<div class="card h-100 border-0 shadow-sm bg-secondary-dark text-white overflow-hidden">
						<div class="card-header border-0 bg-transparent pt-3 pb-0">
							<div class="d-flex align-items-center">
								<i class="fa-solid fa-cloud-sun me-2 fs-5"></i>
								<h3 class="card-title fs-6 fw-bold mb-0 text-white">Local Weather</h3>
							</div>
						</div>
						<div class="card-body d-flex justify-content-center align-items-center pt-0 pb-2 px-2">
							<div id="ww_eb276cd9717e9">
								More forecasts: <a href="https://oneweather.org/orlando/30_days/" id="ww_eb276cd9717e9_u" target="_blank">Orlando weather 30 day</a>
							</div>
						</div>
					</div>
				</div>
				<!-- World Clocks -->
				<div class="col-md-6 col-xl-4">
					<div class="card h-100 border-0 shadow-sm bg-primary-dark text-white overflow-hidden">
						<div class="card-header border-0 bg-transparent pt-3 pb-0">
							<div class="d-flex align-items-center">
								<i class="fa-solid fa-clock me-2 fs-5"></i>
								<h3 class="card-title fs-6 fw-bold mb-0 text-white">World Clocks</h3>
							</div>
						</div>
						<div class="card-body pt-0 pb-2 px-2 d-flex flex-column justify-content-center">
							<div class="analog-clock-container">
								<AnalogClock id="analog-clock-india" label="India" />
								<AnalogClock id="analog-clock-us" label="US" />
								<AnalogClock id="analog-clock-uk" label="UK" />
							</div>
						</div>
					</div>
				</div>

				<!-- Today's Summary -->
				<div class="col-md-12 col-xl-4">
					<div class="card h-100 border-0 shadow-sm bg-primary-dark text-white overflow-hidden">
						<div class="card-header border-0 bg-transparent pt-3 pb-0">
							<div class="d-flex align-items-center">
								<i class="fa-solid fa-calendar-day me-2 fs-5"></i>
								<h3 class="card-title fs-6 fw-bold mb-0 text-white">Today's Summary</h3>
							</div>
						</div>
						<div class="card-body pt-0 pb-4 px-4 d-flex flex-column align-items-center justify-content-center text-center">
							<div class="display-4 fw-bold mb-0" id="dash-today-day">--</div>
							<div class="h5 mb-3 opacity-75" id="dash-today-date-str">--</div>
							
							<div id="daily-quote-container" class="border-top border-bottom border-secondary py-3 my-3 w-100">
								<p class="mb-1 fst-italic small" id="quote-text">"Loading daily quote..."</p>
								<p class="mb-0 text-muted opacity-75 text-end" style="font-size: 0.7rem;" id="quote-author"></p>
							</div>

							<div id="dash-today-events" class="mt-2 w-100">
								<div class="spinner-border spinner-border-sm text-light mb-2"></div>
								<p class="small mb-0">Checking for holidays...</p>
							</div>

							<a href="/utilities/misc/calendar" class="btn btn-outline-light btn-sm mt-4">
								<i class="fas fa-calendar-alt me-1"></i> View Full Calendar
							</a>
						</div>
					</div>
				</div>

				<!-- News Widgets -->
				<div class="col-xl-6">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-header border-0 bg-transparent d-flex justify-content-between align-items-center pt-3 pb-0">
							<div class="d-flex align-items-center">
								<i class="fa-brands fa-x-twitter text-dark me-2 fs-5"></i>
								<h3 class="card-title fs-6 fw-bold mb-0">Twitter Trends</h3>
							</div>
							<span class="text-muted small" id="twitter-region">Worldwide</span>
						</div>
						<div class="card-body p-0">
							<div id="twitter-trends" class="list-group list-group-flush news-scroll twitter-scroll">
								<div class="p-5 text-center"><div class="spinner-border spinner-border-sm text-secondary"></div></div>
							</div>
						</div>
					</div>
				</div>
				<!---Reddit tags -->
				<div class="col-xl-6">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-header border-0 bg-transparent pt-3 pb-0">
							<div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
								<div class="d-flex align-items-center">
									<i class="fa-brands fa-reddit text-danger me-2 fs-5"></i>
									<h3 class="card-title fs-6 fw-bold mb-0" id="reddit-title">r/Technology Top Stories</h3>
								</div>
								<div class="d-flex align-items-center gap-2 reddit-tag-controls">
									<select id="reddit-tag-select" class="form-select form-select-sm" aria-label="Choose Reddit tag">
										<option value="technology" selected>Technology</option>
										<option value="programming">Programming</option>
										<option value="webdev">Web Dev</option>
										<option value="javascript">JavaScript</option>
										<option value="learnprogramming">Learn Programming</option>
										<option value="cybersecurity">Cybersecurity</option>
										<option value="science">Science</option>
										<option value="gadgets">Gadgets</option>
										<option value="artificial">Artificial</option>
										<option value="MachineLearning">Machine Learning</option>
									</select>
									<div class="input-group input-group-sm reddit-tag-search">
										<input id="reddit-tag-search" type="text" class="form-control" placeholder="Search tags" list="reddit-tag-options" aria-label="Search Reddit tags" />
										<button id="reddit-tag-load" class="btn btn-outline-secondary" type="button" title="Load tag">
											<i class="fa-solid fa-magnifying-glass"></i>
										</button>
									</div>
									<datalist id="reddit-tag-options">
										<option value="technology"></option>
										<option value="programming"></option>
										<option value="webdev"></option>
										<option value="javascript"></option>
										<option value="learnprogramming"></option>
										<option value="cybersecurity"></option>
										<option value="science"></option>
										<option value="gadgets"></option>
										<option value="artificial"></option>
										<option value="MachineLearning"></option>
									</datalist>
								</div>
							</div>
						</div>
						<div class="card-body p-0">
							<div id="reddit-news" class="list-group list-group-flush news-scroll">
								<div class="p-5 text-center"><div class="spinner-border spinner-border-sm text-secondary"></div></div>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Interactive Tools Section -->
			<div class="row g-4 mt-2">
				<div class="col-12">
					<div class="card border-0 shadow-sm bg-primary-dark text-white">
						<div class="card-body">
							<div class="row g-3">
								<!-- Doodle Pad -->
								<div class="col-md-3">
									<div class="p-3 border border-secondary rounded h-100 bg-secondary-dark text-center">
										<h6 class="fw-bold mb-3">Doodle Pad</h6>
										<div class="mb-3 d-flex flex-wrap justify-content-center gap-1">
											<button class="btn btn-sm p-0 rounded-circle doodle-palette-btn" style="background: #222222; width: 22px; height: 22px; border: 1px solid #444;" data-color="#222222" title="Black"></button>
											<button class="btn btn-sm p-0 rounded-circle doodle-palette-btn" style="background: #d9534f; width: 22px; height: 22px; border: 1px solid #444;" data-color="#d9534f" title="Red"></button>
											<button class="btn btn-sm p-0 rounded-circle doodle-palette-btn" style="background: #5cb85c; width: 22px; height: 22px; border: 1px solid #444;" data-color="#5cb85c" title="Green"></button>
											<button class="btn btn-sm p-0 rounded-circle doodle-palette-btn" style="background: #428bca; width: 22px; height: 22px; border: 1px solid #444;" data-color="#428bca" title="Blue"></button>
											<button class="btn btn-sm p-0 rounded-circle doodle-palette-btn" style="background: #f0ad4e; width: 22px; height: 22px; border: 1px solid #444;" data-color="#f0ad4e" title="Orange"></button>
											<input type="color" id="doodleColor" value="#222222" class="form-control form-control-sm p-0 border-0 bg-transparent" style="width: 22px; height: 22px; cursor: pointer;">
											<div class="vr mx-1"></div>
											<button class="btn btn-sm btn-outline-light py-0 px-2" id="saveDoodle" title="Save Drawing"><i class="fas fa-save small"></i></button>
											<button class="btn btn-sm btn-outline-light py-0 px-2" id="clearDoodle" title="Clear Pad"><i class="fas fa-eraser small"></i></button>
										</div>
										<div class="mb-3 d-flex align-items-center gap-2 px-1">
											<i class="fas fa-paint-brush small opacity-50"></i>
											<input type="range" id="doodleSize" class="form-range form-range-sm" min="0.5" max="10" step="0.5" value="2">
											<span class="small opacity-50" id="doodleSizeLabel" style="min-width: 35px;">2px</span>
										</div>
										<canvas id="doodlePad" class="border bg-white w-100" style="aspect-ratio:1/1; cursor:crosshair;"></canvas>
									</div>
								</div>
								<!-- Timer -->
								<div class="col-md-3">
									<div class="p-3 border border-secondary rounded h-100 bg-secondary-dark text-center">
										<div class="d-flex justify-content-between align-items-center mb-2">
											<h6 class="fw-bold mb-0">Focus Timer</h6>
											<span class="badge text-bg-light text-dark" id="timer-mode-badge">Stopwatch</span>
										</div>
										<select class="form-select form-select-sm bg-dark text-white border-secondary mb-2" id="timer-mode">
											<option value="stopwatch">Stopwatch</option>
											<option value="countup">Count Up</option>
											<option value="countdown">Countdown</option>
											<option value="pomodoro">Pomodoro</option>
										</select>
										<input
											type="number"
											min="1"
											max="240"
											step="1"
											class="form-control form-control-sm bg-dark text-white border-secondary mb-2"
											id="timer-minutes"
											value="25"
											placeholder="Minutes"
										/>
										<div class="small text-white-50 mb-2" id="timer-helper-text">Tracks elapsed time from zero.</div>
										<div class="display-6 my-3 font-monospace" id="timer-display">00:00:00</div>
										<div class="small text-white-50 mb-3" id="timer-status">Ready</div>
										<div class="d-flex gap-1 justify-content-center flex-wrap mb-2">
											<button class="btn btn-sm btn-primary" id="startTimer">Start</button>
											<button class="btn btn-sm btn-outline-light" id="pauseTimer">Pause</button>
											<button class="btn btn-sm btn-secondary" id="resetTimer">Reset</button>
										</div>
										<div class="d-flex gap-1 justify-content-center flex-wrap">
											<button class="btn btn-sm btn-outline-info timer-preset" data-minutes="5">5m</button>
											<button class="btn btn-sm btn-outline-info timer-preset" data-minutes="15">15m</button>
											<button class="btn btn-sm btn-outline-info timer-preset" data-minutes="25">25m</button>
											<button class="btn btn-sm btn-outline-info timer-preset" data-minutes="60">60m</button>
										</div>
									</div>
								</div>
								<!-- Typing Test -->
								<div class="col-md-3">
									<div class="p-3 border border-secondary rounded h-100 bg-secondary-dark text-center">
										<h6 class="fw-bold">Typing Speed</h6>
										<select id="typing-sample-select" class="form-select form-select-sm bg-dark text-white border-secondary mb-2" aria-label="Choose typing sample">
											<option value="0">Warmup</option>
											<option value="1">Developer Notes</option>
											<option value="2">Product Update</option>
											<option value="3">Focus Sprint</option>
											<option value="4">Long Practice</option>
										</select>
										<div class="small text-white-50 mb-2 typing-sample-text" id="typing-text">The quick brown fox jumps over the lazy dog.</div>
										<textarea id="typing-input" class="form-control form-control-sm bg-dark text-white border-secondary mb-2" rows="5" placeholder="Start typing..."></textarea>
										<div id="typing-stats" class="small fw-bold">WPM: 0 | Acc: 0%</div>
									</div>
								</div>
								<!-- Sudoku Placeholder -->
								<div class="col-md-3">
									<div class="p-3 border border-secondary rounded h-100 bg-secondary-dark text-center">
										<h6 class="fw-bold">Daily Sudoku</h6>
										<div id="sudoku-widget" class="mb-2">
											<div class="alert alert-dark py-2 small border-secondary" id="sudoku-status">Ready to play</div>
											<div id="sudoku-board" class="mb-2 d-flex justify-content-center"></div>
											<div class="d-flex gap-1 justify-content-center">
												<button class="btn btn-sm btn-outline-secondary" id="sudoku-reset">New Puzzle</button>
												<button class="btn btn-sm btn-outline-success" id="sudoku-validate">Validate</button>
												<button class="btn btn-sm btn-outline-warning" id="sudoku-show">Show Answer</button>
												<a href="/games/sudoku" class="btn btn-sm btn-outline-light">Full Game</a>
											</div>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</Content>
</Layout>

<style>
	.bg-secondary-dark { background-color: #2c3e50; }
	.bg-primary-dark { background-color: #1a252f; }
	
	.analog-clock-container {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 1rem;
	}

	.avtar-lg {
		width: 48px;
		height: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.quote-card {
		background: #fff8e1;
		border-left: 4px solid #ffc107;
	}

	.news-scroll {
		max-height: 300px; /* Reduced height */
		overflow-y: auto;
	}
	.twitter-scroll {
		max-height: 300px; /* Reduced height */
		overflow-y: auto;
	}
	.news-item {
		border-left: 3px solid transparent;
		transition: all 0.2s;
	}
	.news-item:hover {
		background-color: rgba(var(--bs-primary-rgb), 0.05);
		border-left-color: var(--bs-primary);
	}
	.reddit-tag-controls {
		flex: 1 1 360px;
		justify-content: flex-end;
	}
	.reddit-tag-controls .form-select {
		max-width: 155px;
	}
	.reddit-tag-search {
		max-width: 230px;
	}
	.typing-sample-text {
		min-height: 4.5rem;
		text-align: left;
	}
	#typing-input {
		min-height: 8rem;
		resize: vertical;
	}
	@media (max-width: 576px) {
		.reddit-tag-controls,
		.reddit-tag-search,
		.reddit-tag-controls .form-select {
			max-width: none;
			width: 100%;
		}
	}
</style>

<script src="https://cdn.jsdelivr.net/npm/signature_pad@4.1.7/dist/signature_pad.umd.min.js" is:inline></script>
<script src="/js/lib/sudoku.js" is:inline></script>
<script src="/js/pages/dashboard.js" is:inline></script>
