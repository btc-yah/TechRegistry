---
import Layout from "../../layouts/Layout.astro";
import Content from "../../layouts/Content.astro";
const pageScript = "/js/pages/encoding/ascii.js";
---
<Layout title="ASCII Encoder and Decoder | TechRegistry">
	<Content title="ASCII Encoder and Decoder" titleTag="Encoding" starCount="4.8k stars" usageCount="7.2k uses today" version="v2.7.1" statusText="All Systems Operational" freeLabel="100% Free" privacyLabel="Client-Side Only" poweredBy="browser-side JS" breadcrumbs={[{ label: "Home", href: "/" }, { label: "ASCII Encoder and Decoder" }]}>
		<div class="tool-page-shell" id="tool-page-root">
			<div class="card"><div class="card-body">
				<div class="tool-toolbar"><button id="tool-load-sample" class="btn btn-outline-light btn-sm" type="button">Load Sample</button><button id="tool-clear" class="btn btn-outline-secondary btn-sm" type="button">Clear</button><button id="tool-run" class="btn btn-primary btn-sm" type="button">Convert</button></div>
				<div class="tool-field-grid mt-3 mb-3"><div><label class="form-label" for="ascii-mode">Mode</label><select id="ascii-mode" class="form-select" data-tool-field="mode"><option value="encode">Text to ASCII</option><option value="decode">ASCII to Text</option></select></div></div>
				<div id="tool-status" class="tool-status">Ready.</div>
				<div class="tool-editors mt-3"><div><div class="tool-label-row"><label for="tool-input" class="form-label mb-0">Input</label><span class="text-body-secondary">Plain text or space-separated ASCII codes</span></div><textarea id="tool-input" class="form-control tool-code-input js-clipboard-source"></textarea></div><div><div class="tool-label-row"><label class="form-label mb-0">Output</label><span class="text-body-secondary">Converted content appears here</span></div><pre id="tool-output" class="tool-code-output"></pre></div></div>
			</div></div>
			<div class="card tool-details-card"><div class="card-header"><h3 class="card-title">About This ASCII Tool</h3></div><div class="card-body"><p>This ASCII encoder and decoder helps inspect character codes while debugging text payloads, parsing older formats, and working with simple transport protocols.</p><p>It is useful for quick browser-side conversion between readable text and decimal ASCII values without extra tooling.</p><ul class="tool-detail-list"><li>Converts text into space-separated ASCII codes.</li><li>Decodes ASCII values back into readable characters.</li><li>Helpful for debugging plain-text protocols and legacy data.</li></ul></div></div>
		</div>
	</Content>
</Layout>
<script type="module" src={pageScript}></script>
