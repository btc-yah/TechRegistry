---
import Layout from "../../layouts/Layout.astro";
import Content from "../../layouts/Content.astro";
const pageScript = "/js/pages/encoding/html-entities.js";
---
<Layout title="HTML Entities Encode and Decode | TechRegistry">
	<Content title="HTML Entities Encode and Decode" titleTag="Encoding" starCount="5.1k stars" usageCount="8.1k uses today" version="v2.7.1" statusText="All Systems Operational" freeLabel="100% Free" privacyLabel="Client-Side Only" breadcrumbs={[{ label: "Home", href: "/" }, { label: "HTML Entities Encode and Decode" }]}>
		<div class="tool-page-shell" id="tool-page-root">
			<div class="card"><div class="card-body">
				<div class="tool-toolbar"><button id="tool-load-sample" class="btn btn-outline-light btn-sm" type="button">Load Sample</button><button id="tool-clear" class="btn btn-outline-secondary btn-sm" type="button">Clear</button><button id="tool-run" class="btn btn-primary btn-sm" type="button">Convert</button></div>
				<div class="tool-field-grid mt-3 mb-3"><div><label class="form-label" for="entities-mode">Mode</label><select id="entities-mode" class="form-select" data-tool-field="mode"><option value="escape">Escape</option><option value="unescape">Unescape</option></select></div></div>
				<div id="tool-status" class="tool-status">Ready.</div>
				<div class="tool-editors mt-3"><div><div class="tool-label-row"><label for="tool-input" class="form-label mb-0">Input</label><span class="text-body-secondary">HTML text or entity-encoded content</span></div><textarea id="tool-input" class="form-control tool-code-input js-clipboard-source"></textarea></div><div><div class="tool-label-row"><label class="form-label mb-0">Output</label><span class="text-body-secondary">Converted content appears here</span></div><pre id="tool-output" class="tool-code-output"></pre></div></div>
			</div></div>
			<div class="card tool-details-card"><div class="card-header"><h3 class="card-title">About This HTML Entities Tool</h3></div><div class="card-body"><p>This HTML entities tool helps encode special characters for markup safety or decode copied entity strings back into normal readable text.</p><p>It is useful for CMS editing, email template debugging, escaped snippet cleanup, and content migration work.</p><ul class="tool-detail-list"><li>Escapes and unescapes common HTML entities.</li><li>Helpful for snippets, templates, and rendered content.</li><li>Keeps conversion private in the browser.</li></ul><div class="tool-points"><a class="tool-point" href="https://github.com/mathiasbynens/he" target="_blank" rel="noreferrer"><i class="fa-solid fa-link"></i>Powered by he</a></div></div></div>
		</div>
	</Content>
</Layout>
<script type="module" src={pageScript}></script>
