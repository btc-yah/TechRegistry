---
import Layout from "../../layouts/Layout.astro";
import Content from "../../layouts/Content.astro";
const pageScript = "/js/pages/encoding/url.js";
---
<Layout title="URL Encode and Decode | TechRegistry">
	<Content title="URL Encode and Decode" titleTag="Encoding" starCount="5.3k stars" usageCount="8.8k uses today" version="v2.7.1" statusText="All Systems Operational" freeLabel="100% Free" privacyLabel="Client-Side Only" breadcrumbs={[{ label: "Home", href: "/" }, { label: "URL Encode and Decode" }]}>
		<div class="tool-page-shell" id="tool-page-root">
			<div class="card"><div class="card-body">
				<div class="tool-toolbar"><button id="tool-load-sample" class="btn btn-outline-light btn-sm" type="button">Load Sample</button><button id="tool-clear" class="btn btn-outline-secondary btn-sm" type="button">Clear</button><button id="tool-run" class="btn btn-primary btn-sm" type="button">Convert</button></div>
				<div class="tool-field-grid mt-3 mb-3"><div><label class="form-label" for="url-mode">Mode</label><select id="url-mode" class="form-select" data-tool-field="mode"><option value="encode">Encode</option><option value="decode">Decode</option></select></div></div>
				<div id="tool-status" class="tool-status">Ready.</div>
				<div class="tool-editors mt-3"><div><div class="tool-label-row"><label for="tool-input" class="form-label mb-0">Input</label><span class="text-body-secondary">Query strings, paths, or full URLs</span></div><textarea id="tool-input" class="form-control tool-code-input js-clipboard-source"></textarea></div><div><div class="tool-label-row"><label class="form-label mb-0">Output</label><span class="text-body-secondary">Converted content appears here</span></div><pre id="tool-output" class="tool-code-output"></pre></div></div>
			</div></div>
			<div class="card tool-details-card"><div class="card-header"><h3 class="card-title">About This URL Encode and Decode Tool</h3></div><div class="card-body"><p>This URL tool helps developers safely encode query values, path fragments, and redirect parameters or decode copied URLs back into readable text.</p><p>It is especially useful in API debugging, redirect handling, frontend routing, and troubleshooting parameter-heavy links.</p><ul class="tool-detail-list"><li>Supports URL encode and decode in one editor.</li><li>Useful for query parameters and callback URLs.</li><li>Runs entirely in the browser.</li></ul><div class="tool-points"><a class="tool-point" href="https://developer.mozilla.org/docs/Web/JavaScript/Reference/Global_Objects/encodeURIComponent" target="_blank" rel="noreferrer"><i class="fa-solid fa-link"></i>Powered by Web URL APIs</a></div></div></div>
		</div>
	</Content>
</Layout>
<script type="module" src={pageScript}></script>
