---
import Layout from "../../layouts/Layout.astro";
import Content from "../../layouts/Content.astro";
const pageScript = "/js/pages/encoding/binary-hex-octal.js";
---
<Layout title="Binary Hex and Octal Converter | TechRegistry">
	<Content title="Binary Hex and Octal Converter" titleTag="Encoding" starCount="4.7k stars" usageCount="6.9k uses today" version="v2.7.1" statusText="All Systems Operational" freeLabel="100% Free" privacyLabel="Client-Side Only" poweredBy="browser-side JS" breadcrumbs={[{ label: "Home", href: "/" }, { label: "Binary Hex and Octal Converter" }]}>
		<div class="tool-page-shell" id="tool-page-root">
			<div class="card"><div class="card-body">
				<div class="tool-toolbar"><button id="tool-load-sample" class="btn btn-outline-light btn-sm" type="button">Load Sample</button><button id="tool-clear" class="btn btn-outline-secondary btn-sm" type="button">Clear</button><button id="tool-run" class="btn btn-primary btn-sm" type="button">Convert</button></div>
				<div class="tool-field-grid mt-3 mb-3">
					<div><label class="form-label" for="base-value">Value</label><input id="base-value" class="form-control" data-tool-field="value" /></div>
					<div><label class="form-label" for="input-base">Input Base</label><select id="input-base" class="form-select" data-tool-field="inputBase"><option value="2">Binary</option><option value="8">Octal</option><option value="10">Decimal</option><option value="16">Hex</option></select></div>
				</div>
				<div id="tool-status" class="tool-status">Ready.</div>
				<div class="mt-3"><div class="tool-label-row"><label class="form-label mb-0">Converted Output</label><span class="text-body-secondary">All number systems appear here</span></div><pre id="tool-output" class="tool-code-output tool-code-output-compact"></pre></div>
			</div></div>
			<div class="card tool-details-card"><div class="card-header"><h3 class="card-title">About This Number Base Converter</h3></div><div class="card-body"><p>This base converter helps switch between binary, decimal, octal, and hexadecimal values while debugging low-level data, bitmasks, color values, and numeric flags.</p><p>It is useful in firmware work, frontend color handling, backend diagnostics, and general developer utilities.</p><ul class="tool-detail-list"><li>Converts one input into decimal, binary, octal, and hex.</li><li>Helpful for debugging and quick numeric inspection.</li><li>Uses lightweight browser-side logic.</li></ul></div></div>
		</div>
	</Content>
</Layout>
<script type="module" src={pageScript}></script>
