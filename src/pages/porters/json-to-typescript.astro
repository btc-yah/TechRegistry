---
import Layout from "../../layouts/Layout.astro";
import Content from "../../layouts/Content.astro";

const pageScript = "/js/pages/porters/json-to-typescript.js";

const sampleJson = `{
  "id": 101,
  "name": "TechRegistry",
  "isActive": true,
  "tags": ["astro", "typescript"],
  "owner": {
    "firstName": "Thila",
    "lastName": "Dev"
  }
}`;

const sampleTypescript = `export interface RootObject {
  id: number;
  name: string;
  isActive: boolean;
  tags: string[];
  owner: Owner;
}

export interface Owner {
  firstName: string;
  lastName: string;
}`;
---

<Layout title="JSON to TypeScript (Interfaces) | TechRegistry">
	<Content
		title="JSON to TypeScript (Interfaces)"
		titleTag="Converter"
		starCount="6.1k stars"
		usageCount="10.3k uses today"
		version="v2.7.1"
		statusText="All Systems Operational"
		freeLabel="100% Free"
		privacyLabel="Client-Side Only"
		breadcrumbs={[
			{ label: "Home", href: "/" },
			{ label: "JSON to TypeScript (Interfaces)" },
		]}
	>
		<div class="tool-page-shell">
			<div class="card">
				<div class="card-body">
					<div class="tool-toolbar">
						<button id="load-sample" class="btn btn-outline-light btn-sm" type="button">Load Sample</button>
						<button id="clear-input" class="btn btn-outline-secondary btn-sm" type="button">Clear</button>
						<button id="generate-typescript" class="btn btn-primary btn-sm" type="button">Generate TypeScript</button>
						<button id="copy-output" class="btn btn-outline-info btn-sm" type="button">Copy Output</button>
					</div>

					<div class="tool-field-grid mt-3 mb-3">
						<div>
							<label for="root-name" class="form-label">Root Interface</label>
							<input id="root-name" class="form-control" value="RootObject" placeholder="RootObject" />
						</div>
						<div class="form-check">
							<input class="form-check-input" type="checkbox" id="use-export-keyword" checked />
							<label class="form-check-label" for="use-export-keyword">Include export keyword</label>
						</div>
						<div class="form-check">
							<input class="form-check-input" type="checkbox" id="prefer-type-alias" />
							<label class="form-check-label" for="prefer-type-alias">Use type aliases for root arrays</label>
						</div>
					</div>

					<div class="tool-editors">
						<div>
							<div class="tool-label-row">
								<label for="json-input" class="form-label mb-0">JSON Input</label>
								<span class="text-body-secondary">Paste a JSON object or array</span>
							</div>
							<textarea id="json-input" class="form-control tool-code-input js-clipboard-source">{sampleJson}</textarea>
						</div>

						<div>
							<div class="tool-label-row">
								<label class="form-label mb-0">Generated TypeScript</label>
								<span class="text-body-secondary">Interfaces appear here</span>
							</div>
							<pre id="typescript-output" class="tool-code-output">{sampleTypescript}</pre>
						</div>
					</div>
				</div>
			</div>

			<div class="card tool-details-card">
				<div class="card-header">
					<h3 class="card-title">About This JSON to TypeScript Tool</h3>
				</div>
				<div class="card-body">
					<p>
						Generate TypeScript interfaces from sample JSON when you need a quick starting point for frontend apps,
						SDKs, test data, and typed API integrations.
					</p>
					<p>
						The generator infers nested interfaces, arrays, union-friendly null handling, and common scalar types.
						It works well for React apps, service clients, state models, mocked endpoints, and schema-first UI work.
					</p>
					<ul class="tool-detail-list">
						<li>Useful for both object payloads and array payloads.</li>
						<li>Supports export control and root array alias generation.</li>
						<li>Includes detailed page UI and working toolbar actions.</li>
						<li>Uses page-local JavaScript with no shared tool bootstrap.</li>
					</ul>
					<div class="tool-points"><span class="tool-point"><i class="fa-solid fa-code"></i>Powered by browser-side JS</span></div>
					<p>
						It works well for frontend applications, SDKs, typed service clients, state models, and test fixtures when you need a fast interface-first view of incoming JSON structures.
					</p>
				</div>
			</div>
		</div>
	</Content>
</Layout>

<div
	hidden
	data-json-to-typescript-config
	data-sample-json={encodeURIComponent(sampleJson)}
	data-sample-typescript={encodeURIComponent(sampleTypescript)}
></div>

<script type="module" src={pageScript}></script>
