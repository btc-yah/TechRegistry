---
import Layout from "../../../layouts/Layout.astro";
import Content from "../../../layouts/Content.astro";

const pageScript = "/js/pages/utilities/misc/task-handler.js";
---

<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/main.min.css" rel="stylesheet" />

<Layout title="Task Handler | TechRegistry">
	<Content
		title="Task Handler"
		titleTag="Planner Board"
		subtitle="Plan, edit, and track personal task events in an AdminLTE-inspired calendar workspace saved directly in your browser."
		version="v1.0.0"
		statusText="Local First"
		privacyLabel="Stored In Browser"
		poweredBy="TechRegistry UI"
		breadcrumbs={[{ label: "Home", href: "/" }, { label: "Task Handler" }]}
	>
		<div class="task-handler-page" data-bs-theme="light">
			<div class="row g-4 align-items-start">
				<div class="col-12 col-xl-4">
					<div class="card shadow-sm">
						<div class="card-header">
							<h3 class="h6 mb-1 fw-semibold">Task Events</h3>
							<p class="text-body-secondary small mb-0">Click any date on the calendar to add a task, or an event to edit it.</p>
						</div>
						<div class="card-body">
							<div class="row g-3 mt-1">
								<div class="col-12 col-md-4 col-xl-12 col-xxl-4"> 
									<div class="border rounded-4 bg-light p-3 h-100  d-flex flex-column justify-content-center align-items-center text-center"> 
										<div class="text-uppercase small text-body-secondary">Total</div> 
										<div class="fs-4 fw-semibold mt-1 justify-content-center" id="totalTasks">1</div> 
									</div> 
								</div>
								<div class="col-12 col-md-4 col-xl-12 col-xxl-4">
									<div class="border rounded-4 bg-light p-3 h-100  d-flex flex-column justify-content-center align-items-center text-center">
										<div class="text-uppercase small text-body-secondary">Month</div>
										<div class="fs-4 fw-semibold mt-1 justify-content-center" id="monthTasks">0</div>
									</div>
								</div>
								<div class="col-12 col-md-4 col-xl-12 col-xxl-4">
									<div class="border rounded-4 bg-light p-3 h-100  d-flex flex-column justify-content-center align-items-center text-center">
										<div class="text-uppercase small text-body-secondary">Today</div>
										<div class="fs-4 fw-semibold mt-1 justify-content-center" id="todayTasks">0</div>
									</div>
								</div>
							</div>
						</div>
					</div>

					<div class="card shadow-sm mt-4">
						<div class="card-header d-flex justify-content-between align-items-center">
							<h3 class="h6 mb-0 fw-semibold">Upcoming</h3>
							<span class="small text-body-secondary ms-auto" id="upcomingCount">0 items</span>
						</div>
						<div class="card-body p-3">
							<div class="d-grid gap-2" id="upcomingEvents"></div>
						</div>
					</div>
				</div>

				<div class="col-12 col-xl-8">
					<div class="card shadow-sm overflow-hidden">
						<div class="card-header bg-primary text-white border-0 px-3 px-md-4 py-3">
							<div class="d-grid task-calendar-head align-items-center">
								<button class="btn btn-link text-white p-0 task-nav-btn" id="prevBtn" type="button" aria-label="Previous month">
									<i class="fas fa-caret-left fa-lg"></i>
								</button>
								<div class="text-center">
									<h2 class="h3 text-white mb-0 text-uppercase" id="monthText">April</h2>
									<div class="small fw-semibold opacity-75 text-uppercase" id="yearText">2026</div>
								</div>
								<button class="btn btn-link text-white p-0 task-nav-btn ms-auto" id="nextBtn" type="button" aria-label="Next month">
									<i class="fas fa-caret-right fa-lg"></i>
								</button>
							</div>
						</div>

						<div class="card-body bg-light p-3 p-md-4">
							<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
								<div class="d-flex flex-wrap gap-2">
									<button class="btn btn-outline-primary" id="todayBtn" type="button">Today</button>
									<button class="btn btn-primary" id="newTaskBtn" type="button">
										<i class="fas fa-calendar-plus me-1"></i>New Task
									</button>
								</div>
							</div>

							<div id="calendar" class="fc-theme-bootstrap5"></div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="modal fade" id="taskEventModal" tabindex="-1" aria-labelledby="taskEventModalLabel" aria-hidden="true" data-bs-theme="light">
			<div class="modal-dialog modal-dialog-centered modal-lg">
				<div class="modal-content border-0 shadow">
					<div class="modal-header">
						<div>
							<h5 class="modal-title" id="taskEventModalLabel">Add Task</h5>
							<p class="mb-0 small text-body-secondary" id="taskModalHint">Schedule a task for the selected date.</p>
						</div>
						<button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
					</div>
					<form id="eventForm">
						<div class="modal-body">
							<input type="hidden" id="eventId" />
							<input type="hidden" id="eventColor" value="#0d6efd" />

							<div class="d-flex flex-wrap gap-2 mb-3" id="presetColorOptions" aria-label="Task color palette">
								<button class="task-color-chip is-active" type="button" data-color="#0d6efd" aria-label="Blue"></button>
								<button class="task-color-chip" type="button" data-color="#20c997" aria-label="Green"></button>
								<button class="task-color-chip" type="button" data-color="#ffc107" aria-label="Yellow"></button>
								<button class="task-color-chip" type="button" data-color="#dc3545" aria-label="Red"></button>
								<button class="task-color-chip" type="button" data-color="#6f42c1" aria-label="Violet"></button>
								<button class="task-color-chip" type="button" data-color="#fd7e14" aria-label="Orange"></button>
							</div>

							<div class="mb-3">
								<label class="form-label" for="eventTitle">Task title</label>
								<input id="eventTitle" class="form-control" type="text" placeholder="Prepare release notes" maxlength="80" required />
							</div>

							<div class="row g-3">
								<div class="col-12 col-sm-6">
									<label class="form-label" for="eventStartDate">Start date</label>
									<input id="eventStartDate" class="form-control" type="date" required />
								</div>
								<div class="col-12 col-sm-6">
									<label class="form-label" for="eventStartTime">Start time</label>
									<input id="eventStartTime" class="form-control" type="time" />
								</div>
								<div class="col-12 col-sm-6">
									<label class="form-label" for="eventEndDate">End date</label>
									<input id="eventEndDate" class="form-control" type="date" required />
								</div>
								<div class="col-12 col-sm-6">
									<label class="form-label" for="eventEndTime">End time</label>
									<input id="eventEndTime" class="form-control" type="time" />
								</div>
							</div>

							<div class="mt-3">
								<label class="form-label" for="eventDetails">Notes</label>
								<textarea id="eventDetails" class="form-control js-clipboard-source" rows="4" placeholder="Add extra task details or context."></textarea>
							</div>
						</div>
						<div class="modal-footer justify-content-between">
							<button class="btn btn-outline-danger d-none" id="deleteEventBtn" type="button">Delete</button>
							<div class="d-flex gap-2 ms-auto">
								<button class="btn btn-outline-secondary" id="resetEventBtn" type="button">Clear</button>
								<button class="btn btn-primary" id="saveEventBtn" type="submit">
									<i class="fas fa-plus me-1"></i><span id="saveEventLabel">Add Task</span>
								</button>
							</div>
						</div>
					</form>
				</div>
			</div>
		</div>
	</Content>
</Layout>

<style is:global>
	.task-handler-page {
		--task-calendar-accent: #67b7ff;
		--task-calendar-accent-deep: #3498eb;
		--task-calendar-surface: #f3f9ff;
		--task-calendar-grid: #d5e6f7;
		--task-calendar-text: #55708c;
		--task-calendar-muted: #58aef7;
		--task-calendar-shadow: 0 20px 45px rgba(26, 33, 52, 0.08);
	}
	.task-handler-page .card {
		border: 1px solid rgba(103, 183, 255, 0.14);
		border-radius: 1rem;
		box-shadow: var(--task-calendar-shadow);
		background: #ffffff;
	}
	.task-handler-page .card-header {
		border-bottom-color: rgba(103, 183, 255, 0.18);
		background: #ffffff;
	}
	.task-handler-page .card-body {
		background: #ffffff;
	}
	.task-calendar-head {
		grid-template-columns: 2rem 1fr 2rem;
	}
	.task-nav-btn {
		width: 2rem;
		height: 2rem;
		border-radius: 999px;
	}
	.task-nav-btn:hover {
		background: rgba(255, 255, 255, 0.18);
	}
    /* Calendar Overrides to match AdminLTE */
    #calendar {
        min-height: 600px;
    }
    .fc .fc-toolbar-title {
        font-size: 1.25rem;
        text-transform: uppercase;
        font-weight: 700;
        color: var(--task-calendar-text);
    }
    .fc .fc-button-primary {
        background-color: var(--bs-primary);
        border-color: var(--bs-primary);
    }
    /* FullCalendar Today Highlight */
    .fc .fc-daygrid-day.fc-day-today {
        background-color: var(--task-calendar-surface) !important;
    }
    .fc .fc-daygrid-day.fc-day-today .fc-dom-1 {
        color: var(--task-calendar-accent-deep);
    }
    /* Calendar Link Styling */
    .fc a {
        text-decoration: none;
        color: inherit;
    }
	.task-event-pill {
		display: block;
		width: 100%;
		border: 0;
		border-radius: 0.5rem;
		padding: 0.4rem 0.5rem;
		color: #fff;
		text-align: left;
		font-size: 0.75rem;
		line-height: 1.2;
	}
	.task-event-pill strong,
	.task-event-pill span {
		display: block;
		color: inherit;
	}
	.task-event-pill span {
		font-size: 0.68rem;
		opacity: 0.92;
		margin-top: 0.15rem;
	}
	.task-color-chip {
		width: 2rem;
		height: 2rem;
		border-radius: 999px;
		border: 2px solid rgba(255, 255, 255, 0.9);
		box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.12);
	}
	.task-color-chip.is-active {
		box-shadow: 0 0 0 2px var(--bs-primary);
	}
	.task-color-chip[data-color="#0d6efd"] { background: #0d6efd; }
	.task-color-chip[data-color="#20c997"] { background: #20c997; }
	.task-color-chip[data-color="#ffc107"] { background: #ffc107; }
	.task-color-chip[data-color="#dc3545"] { background: #dc3545; }
	.task-color-chip[data-color="#6f42c1"] { background: #6f42c1; }
	.task-color-chip[data-color="#fd7e14"] { background: #fd7e14; }
	.task-upcoming-item {
		width: 100%;
		border: 1px solid var(--bs-border-color);
		border-radius: var(--bs-border-radius-lg);
		background: var(--bs-body-bg);
		padding: 0.85rem 1rem;
		text-align: left;
	}
	.task-upcoming-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		margin-bottom: 0.25rem;
	}
	.task-upcoming-title {
		font-weight: 600;
		color: var(--bs-emphasis-color);
	}
	.task-upcoming-time,
	.task-upcoming-date,
	.task-upcoming-notes,
	.task-empty-state {
		font-size: 0.875rem;
		color: var(--bs-secondary-color);
	}
	.task-empty-state {
		border: 1px dashed var(--bs-border-color);
		border-radius: var(--bs-border-radius-lg);
		padding: 1rem;
		text-align: center;
		background: #ffffff;
	}
	@media (max-width: 767.98px) {
		.task-event-pill {
			padding: 0.3rem 0.4rem;
			font-size: 0.68rem;
		}
		.task-event-pill span {
			display: none;
		}
	}
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
<script type="module" src={pageScript}></script>
