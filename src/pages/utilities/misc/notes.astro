---
import Layout from "../../../layouts/Layout.astro";
import Content from "../../../layouts/Content.astro";

const pageScript = "/js/pages/utilities/misc/notes.js";
---

<Layout title="Notes | TechRegistry">
	<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet" slot="head" />

	<Content title="Notes" titleTag="Misc" breadcrumbs={[{ label: "Home", href: "/" }, { label: "Notes" }]}>
		<div class="container py-2">
			<!-- Search Bar and Add Button -->
			<div class="row justify-content-center mb-5">
				<div class="col-md-8 col-lg-7">
					<div class="d-flex gap-2">
						<div class="card shadow-sm border-0 bg-light flex-grow-1">
							<div class="card-body p-0">
								<input type="text" id="searchNotes" class="text-dark form-control border-0 shadow-none py-2 px-3 bg-transparent" placeholder="Search your notes..." />
							</div>
						</div>
						<button class="btn btn-primary shadow-sm create-trigger px-4" data-bs-toggle="modal" data-bs-target="#noteModal">
							<i class="fas fa-plus me-2"></i> Add Note
						</button>
					</div>
				</div>
			</div>

			<!-- Notes Grid -->
			<div id="notesList" class="notes-container"></div>
		</div>
	</Content>

	<!-- Note Modal (Create & Edit) -->
	<div class="modal fade" id="noteModal" tabindex="-1" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered modal-lg">
			<div class="modal-content border-0 shadow">
				<div class="modal-header border-0 pb-0">
					<h5 class="modal-title fw-bold" id="modalTitle">Note</h5>
					<button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body p-4">
					<input type="text" id="noteTitleInput" class="form-control border-0 fw-bold mb-3 shadow-none p-0 fs-4" placeholder="Title" />
					<div id="noteEditor" style="height: 300px; border: none;"></div>
				</div>
				<div class="modal-footer border-0 p-3">
					<button type="button" class="btn btn-outline-danger btn-sm" id="deleteBtn">
						Delete
					</button>
					<div class="ms-auto">
						<button type="button" class="btn btn-link text-dark text-decoration-none btn-sm fw-bold shadow-none" data-bs-dismiss="modal">Cancel</button>
						<button type="button" class="btn btn-primary btn-sm px-4 shadow-none fw-bold" id="saveBtn">Save</button>
					</div>
				</div>
			</div>
		</div>
	</div>
</Layout>

<script is:inline src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
<script type="module" src={pageScript}></script>

<style is:global>
	.ql-toolbar.ql-snow {
		border: none !important;
		border-bottom: 1px solid #eee !important;
		padding: 8px 0 !important;
	}
	.ql-container.ql-snow {
		border: none !important;
		font-family: inherit !important;
		font-size: 1rem !important;
	}

	.notes-container {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
		gap: 16px;
		padding: 20px 0;
	}

	.note-card {
		background: white;
		border: 1px solid #e0e0e0;
		border-radius: 8px;
		padding: 15px;
		transition: box-shadow 0.2s, transform 0.2s;
		cursor: pointer;
		aspect-ratio: 1 / 1;
		display: flex;
		flex-direction: column;
		text-align: left;
		box-shadow: 0 1px 2px 0 rgba(60,64,67,0.3), 0 1px 3px 1px rgba(60,64,67,0.15);
		overflow: hidden;
	}

	.note-card:hover {
		box-shadow: 0 1px 3px 0 rgba(60,64,67,0.3), 0 4px 8px 3px rgba(60,64,67,0.15);
	}

	.note-card h6 {
		margin-bottom: 8px !important;
		width: 100%;
		color: black !important;
		flex-shrink: 0;
		white-space: normal;
		word-break: break-word;
	}

	.note-preview-content {
		flex-grow: 1;
		overflow-y: auto;
		overflow-x: hidden;
		color: black !important;
		font-size: 0.875rem;
		word-break: break-word;
		padding-right: 4px;
		min-height: 0; /* Critical for flexbox scrolling */
		white-space: normal;
	}

	.note-preview-content * {
		color: black !important;
	}

	.note-preview-content::-webkit-scrollbar {
		width: 6px;
	}

	.note-preview-content::-webkit-scrollbar-track {
		background: transparent;
	}

	.note-preview-content::-webkit-scrollbar-thumb {
		background: #bbb;
		border-radius: 10px;
	}

	.note-preview-content:hover::-webkit-scrollbar-thumb {
		background: #999;
	}

	.note-footer {
		flex-shrink: 0;
		padding-top: 8px;
	}

	.note-time {
		font-size: 0.7rem;
		color: #5f6368;
	}

	.note-delete, .note-open {
		font-size: 0.85rem;
		cursor: pointer;
	}

	.note-delete {
		opacity: 0;
		transition: opacity 0.2s;
	}

	.note-card:hover .note-delete {
		opacity: 1;
	}

	/* Note Modal Styling */
	#noteModal .modal-content {
		border-radius: 12px;
	}

	#noteModal .modal-header {
		padding: 1.25rem 1.5rem 0.5rem;
	}

	#noteModal .modal-body {
		padding: 0 1.5rem 1.5rem !important;
	}

	#noteModal .modal-footer {
		padding: 0.75rem 1.5rem 1.25rem;
	}

	#noteTitleInput::placeholder {
		color: #999;
		font-weight: 500;
	}

	/* Quill Editor specific styles for the modal */
	.ql-editor {
		background-color: white;
		padding: 12px 0 !important; /* Align with title */
	}

	.ql-container.ql-snow {
		font-size: 1.1rem !important;
	}
</style>
