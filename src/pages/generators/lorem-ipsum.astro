---
import Layout from "../../layouts/Layout.astro";
import Content from "../../layouts/Content.astro";
const pageScript = "/js/pages/generators/lorem-ipsum.js";
---
<Layout title="Lorem Ipsum Generator | TechRegistry"><Content title="Lorem Ipsum Generator" titleTag="Generator" starCount="4.7k stars" usageCount="6.8k uses today" version="v2.7.1" statusText="All Systems Operational" freeLabel="100% Free" privacyLabel="Client-Side Only" breadcrumbs={[{ label: "Home", href: "/" }, { label: "Lorem Ipsum Generator" }]}><div class="tool-page-shell" id="tool-page-root"><div class="card"><div class="card-body"><div class="tool-toolbar"><button id="tool-load-sample" class="btn btn-outline-light btn-sm" type="button">Load Sample</button><button id="tool-clear" class="btn btn-outline-secondary btn-sm" type="button">Clear</button><button id="tool-run" class="btn btn-primary btn-sm" type="button">Generate</button></div><div class="tool-field-grid mt-3 mb-3"><div><label class="form-label" for="lorem-mode">Mode</label><select id="lorem-mode" class="form-select" data-tool-field="mode"><option value="paragraphs">Paragraphs</option><option value="sentences">Sentences</option><option value="words">Words</option></select></div><div><label class="form-label" for="lorem-count">Count</label><input id="lorem-count" class="form-control" data-tool-field="count" value="3" /></div></div><div id="tool-status" class="tool-status">Ready.</div><div class="mt-3"><pre id="tool-output" class="tool-code-output"></pre></div></div></div><div class="card tool-details-card"><div class="card-header"><h3 class="card-title">About This Lorem Ipsum Generator</h3></div><div class="card-body"><p>This lorem ipsum generator creates placeholder text for layouts, design mockups, CMS previews, product pages, documentation drafts, and component states.</p><p>It is useful when real copy is not ready yet but you still need realistic paragraph length, line wrapping, spacing, and visual density while building or reviewing an interface.</p><ul class="tool-detail-list"><li>Generates placeholder paragraphs, sentences, or words.</li><li>Good for web layouts, wireframes, content scaffolding, and responsive previews.</li><li>Uses lightweight browser-side logic for fast local generation.</li></ul><div class="tool-points"><span class="tool-point"><i class="fa-solid fa-code"></i>Powered by browser-side JS</span></div></div></div></div></Content></Layout><script type="module" src={pageScript}></script>
