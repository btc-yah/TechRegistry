---
import Layout from "../../layouts/Layout.astro";
import Content from "../../layouts/Content.astro";
const pageScript = "/js/pages/generators/password.js";
---
<Layout title="Password Generator | TechRegistry"><Content title="Password Generator" titleTag="Generator" starCount="5.8k stars" usageCount="9.7k uses today" version="v2.7.1" statusText="All Systems Operational" freeLabel="100% Free" privacyLabel="Client-Side Only" breadcrumbs={[{ label: "Home", href: "/" }, { label: "Password Generator" }]}><div class="tool-page-shell" id="tool-page-root"><div class="card"><div class="card-body"><div class="tool-toolbar"><button id="tool-load-sample" class="btn btn-outline-light btn-sm" type="button">Load Sample</button><button id="tool-clear" class="btn btn-outline-secondary btn-sm" type="button">Clear</button><button id="tool-run" class="btn btn-primary btn-sm" type="button">Generate</button></div><div class="tool-field-grid mt-3 mb-3"><div><label class="form-label" for="password-length">Length</label><input id="password-length" class="form-control" data-tool-field="length" value="16" /></div><div><label class="form-label" for="password-count">Count</label><input id="password-count" class="form-control" data-tool-field="count" value="5" /></div><div class="form-check"><input class="form-check-input" id="password-uppercase" type="checkbox" data-tool-field="uppercase" checked /><label class="form-check-label" for="password-uppercase">Uppercase</label></div><div class="form-check"><input class="form-check-input" id="password-lowercase" type="checkbox" data-tool-field="lowercase" checked /><label class="form-check-label" for="password-lowercase">Lowercase</label></div><div class="form-check"><input class="form-check-input" id="password-numbers" type="checkbox" data-tool-field="numbers" checked /><label class="form-check-label" for="password-numbers">Numbers</label></div><div class="form-check"><input class="form-check-input" id="password-symbols" type="checkbox" data-tool-field="symbols" checked /><label class="form-check-label" for="password-symbols">Symbols</label></div></div><div id="tool-status" class="tool-status">Ready.</div><div class="mt-3"><pre id="tool-output" class="tool-code-output"></pre></div></div></div><div class="card tool-details-card"><div class="card-header"><h3 class="card-title">About This Password Generator</h3></div><div class="card-body"><p>This password generator creates random passwords for account setup, development environments, staging data, QA flows, and admin onboarding tasks.</p><p>You can adjust length, quantity, uppercase letters, lowercase letters, numbers, and symbols to match different password policy requirements while keeping generation fully client-side.</p><ul class="tool-detail-list"><li>Controls password length, count, and character sets.</li><li>Good for strong test credentials, secure defaults, demos, and operational workflows.</li><li>Uses browser-side randomness through the Web Crypto API.</li></ul><div class="tool-points"><a class="tool-point" href="https://developer.mozilla.org/docs/Web/API/Crypto/getRandomValues" target="_blank" rel="noreferrer"><i class="fa-solid fa-link"></i>Powered by Web Crypto</a></div></div></div></div></Content></Layout><script type="module" src={pageScript}></script>
