---
import Layout from "../../layouts/Layout.astro";
import Content from "../../layouts/Content.astro";
const pageScript = "/js/pages/generators/hmac.js";
---
<Layout title="HMAC Generator | TechRegistry"><Content title="HMAC Generator" titleTag="Generator" starCount="5.1k stars" usageCount="7.9k uses today" version="v2.7.1" statusText="All Systems Operational" freeLabel="100% Free" privacyLabel="Client-Side Only" breadcrumbs={[{ label: "Home", href: "/" }, { label: "HMAC Generator" }]}><div class="tool-page-shell" id="tool-page-root"><div class="card"><div class="card-body"><div class="tool-toolbar"><button id="tool-load-sample" class="btn btn-outline-light btn-sm" type="button">Load Sample</button><button id="tool-clear" class="btn btn-outline-secondary btn-sm" type="button">Clear</button><button id="tool-run" class="btn btn-primary btn-sm" type="button">Generate HMAC</button></div><div class="tool-field-grid mt-3 mb-3"><div><label class="form-label" for="hmac-algo">Algorithm</label><select id="hmac-algo" class="form-select" data-tool-field="algorithm"><option value="SHA-256">SHA-256</option><option value="SHA-384">SHA-384</option><option value="SHA-512">SHA-512</option></select></div><div><label class="form-label" for="hmac-secret">Secret</label><input id="hmac-secret" class="form-control" data-tool-field="secret" /></div><div class="w-100"><label class="form-label" for="hmac-source">Source</label><textarea id="hmac-source" class="form-control tool-code-input js-clipboard-source" data-tool-field="source" style="min-height: 18rem;"></textarea></div></div><div id="tool-status" class="tool-status">Ready.</div><div class="mt-3"><pre id="tool-output" class="tool-code-output tool-code-output-compact"></pre></div></div></div><div class="card tool-details-card"><div class="card-header"><h3 class="card-title">About This HMAC Generator</h3></div><div class="card-body"><p>This HMAC generator signs text or payload content with a shared secret, which is helpful for webhook testing, API authentication examples, request verification, and integration debugging.</p><p>Developers can generate HMAC SHA-256, SHA-384, or SHA-512 signatures locally in the browser before comparing them with server logs, provider dashboards, or automated test cases.</p><ul class="tool-detail-list"><li>Supports HMAC signatures with SHA-256, SHA-384, and SHA-512.</li><li>Useful for webhook validation, API auth testing, and signed request troubleshooting.</li><li>Runs client-side using Web Crypto so sample secrets and payloads stay in the browser.</li></ul><div class="tool-points"><a class="tool-point" href="https://developer.mozilla.org/docs/Web/API/SubtleCrypto/sign" target="_blank" rel="noreferrer"><i class="fa-solid fa-link"></i>Powered by Web Crypto</a></div></div></div></div></Content></Layout><script type="module" src={pageScript}></script>
