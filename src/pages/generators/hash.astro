---
import Layout from "../../layouts/Layout.astro";
import Content from "../../layouts/Content.astro";
const pageScript = "/js/pages/generators/hash.js";
---
<Layout title="Hash Generator | TechRegistry"><Content title="Hash Generator" titleTag="Generator" starCount="5.4k stars" usageCount="8.9k uses today" version="v2.7.1" statusText="All Systems Operational" freeLabel="100% Free" privacyLabel="Client-Side Only" breadcrumbs={[{ label: "Home", href: "/" }, { label: "Hash Generator" }]}><div class="tool-page-shell" id="tool-page-root"><div class="card"><div class="card-body"><div class="tool-toolbar"><button id="tool-load-sample" class="btn btn-outline-light btn-sm" type="button">Load Sample</button><button id="tool-clear" class="btn btn-outline-secondary btn-sm" type="button">Clear</button><button id="tool-run" class="btn btn-primary btn-sm" type="button">Generate Hash</button></div><div class="tool-field-grid mt-3 mb-3"><div><label class="form-label" for="hash-algo">Algorithm</label><select id="hash-algo" class="form-select" data-tool-field="algorithm"><option value="SHA-256">SHA-256</option><option value="SHA-384">SHA-384</option><option value="SHA-512">SHA-512</option></select></div><div class="w-100"><label class="form-label" for="hash-source">Source</label><textarea id="hash-source" class="form-control tool-code-input js-clipboard-source" data-tool-field="source" style="min-height: 20rem;"></textarea></div></div><div id="tool-status" class="tool-status">Ready.</div><div class="mt-3"><pre id="tool-output" class="tool-code-output tool-code-output-compact"></pre></div></div></div><div class="card tool-details-card"><div class="card-header"><h3 class="card-title">About This Hash Generator</h3></div><div class="card-body"><p>This hash generator creates deterministic SHA digests for text, JSON payloads, webhook examples, release notes, checksum workflows, and automated test expectations.</p><p>It is useful when you need to compare whether two payloads are identical, document expected hashes, validate copied content, or create browser-side digests without sending source text to a server.</p><ul class="tool-detail-list"><li>Supports SHA-256, SHA-384, and SHA-512 hash algorithms.</li><li>Useful for checksums, payload verification, fixture generation, and debugging signatures.</li><li>Runs fully in the browser through the Web Crypto API.</li></ul><div class="tool-points"><a class="tool-point" href="https://developer.mozilla.org/docs/Web/API/SubtleCrypto/digest" target="_blank" rel="noreferrer"><i class="fa-solid fa-link"></i>Powered by Web Crypto</a></div></div></div></div></Content></Layout><script type="module" src={pageScript}></script>
