---
import Layout from "../../layouts/Layout.astro";
import Content from "../../layouts/Content.astro";

const pageScript = "/js/pages/generators/css-gradient.js";
---

<Layout title="CSS Gradient Generator | TechRegistry">
	<Content title="CSS Gradient Generator" titleTag="Generator" starCount="5.2k stars" usageCount="8.2k uses today" version="v2.7.1" statusText="All Systems Operational" freeLabel="100% Free" privacyLabel="Client-Side Only" poweredBy="browser-side JS" breadcrumbs={[{ label: "Home", href: "/" }, { label: "CSS Gradient Generator" }]}>
		<div class="tool-page-shell" id="tool-page-root">
			<div class="card">
				<div class="card-body">
					<div class="tool-toolbar">
						<button id="tool-load-sample" class="btn btn-outline-light btn-sm" type="button">Load Sample</button>
						<button id="tool-clear" class="btn btn-outline-secondary btn-sm" type="button">Clear</button>
						<button id="tool-run" class="btn btn-primary btn-sm" type="button">Generate Gradient</button>
					</div>
					<div class="tool-field-grid mt-3 mb-3">
						<div>
							<label class="form-label" for="gradient-start">Start Color</label>
							<input id="gradient-start" class="form-control" data-tool-field="start" value="#0d6efd" />
						</div>
						<div>
							<label class="form-label" for="gradient-end">End Color</label>
							<input id="gradient-end" class="form-control" data-tool-field="end" value="#20c997" />
						</div>
						<div>
							<label class="form-label" for="gradient-angle">Angle</label>
							<input id="gradient-angle" class="form-control" data-tool-field="angle" value="135" />
						</div>
					</div>
					<div id="tool-status" class="tool-status">Ready.</div>
					<div class="mt-3">
						<div class="tool-label-row">
							<label class="form-label mb-0">Generated CSS</label>
							<span class="text-body-secondary">Linear gradient code appears here</span>
						</div>
						<pre id="tool-output" class="tool-code-output tool-code-output-compact"></pre>
					</div>
				</div>
			</div>

			<div class="card tool-details-card">
				<div class="card-header"><h3 class="card-title">About This CSS Gradient Generator</h3></div>
				<div class="card-body">
					<p>This CSS gradient generator builds linear-gradient declarations from two colors and an angle, making it quick to create background styles for landing pages, dashboards, cards, banners, and prototypes.</p>
					<p>It helps front-end developers, designers, and content teams produce copy-ready CSS without memorizing the exact gradient syntax or repeatedly tweaking stylesheet fragments by hand.</p>
					<ul class="tool-detail-list">
						<li>Generates clean CSS linear-gradient background declarations.</li>
						<li>Supports custom start color, end color, and degree angle values.</li>
						<li>Useful for hero sections, UI states, component themes, and design experiments.</li>
					</ul>
					<div class="tool-points"><span class="tool-point"><i class="fa-solid fa-code"></i>Powered by browser-side JS</span></div>
				</div>
			</div>
		</div>
	</Content>
</Layout>

<script type="module" src={pageScript}></script>
