---
import Layout from "../../layouts/Layout.astro";
import Content from "../../layouts/Content.astro";
const pageScript = "/js/pages/generators/user-agent.js";
---
<Layout title="User Agent Generator | TechRegistry"><Content title="User Agent Generator" titleTag="Generator" starCount="4.8k stars" usageCount="6.7k uses today" version="v2.7.1" statusText="All Systems Operational" freeLabel="100% Free" privacyLabel="Client-Side Only" breadcrumbs={[{ label: "Home", href: "/" }, { label: "User Agent Generator" }]}><div class="tool-page-shell" id="tool-page-root"><div class="card"><div class="card-body"><div class="tool-toolbar"><button id="tool-load-sample" class="btn btn-outline-light btn-sm" type="button">Load Sample</button><button id="tool-clear" class="btn btn-outline-secondary btn-sm" type="button">Clear</button><button id="tool-run" class="btn btn-primary btn-sm" type="button">Generate</button></div><div class="tool-field-grid mt-3 mb-3"><div><label class="form-label" for="ua-browser">Browser</label><select id="ua-browser" class="form-select" data-tool-field="browser"><option value="chrome">Chrome</option><option value="firefox">Firefox</option><option value="edge">Edge</option><option value="safari">Safari</option></select></div><div><label class="form-label" for="ua-platform">Platform</label><select id="ua-platform" class="form-select" data-tool-field="platform"><option value="windows">Windows</option><option value="macos">macOS</option><option value="linux">Linux</option><option value="android">Android</option></select></div></div><div id="tool-status" class="tool-status">Ready.</div><div class="mt-3"><pre id="tool-output" class="tool-code-output tool-code-output-compact"></pre></div></div></div><div class="card tool-details-card"><div class="card-header"><h3 class="card-title">About This User Agent Generator</h3></div><div class="card-body"><p>This user agent generator creates realistic browser user-agent strings for Chrome, Firefox, Edge, and Safari across common desktop and mobile platform presets.</p><p>It is useful for analytics testing, crawler simulation, backend routing checks, browser detection logic, fixture creation, and debugging code paths that depend on request headers.</p><ul class="tool-detail-list"><li>Supports common browser and platform combinations.</li><li>Useful for tests, log examples, QA data, and conditional browser behavior checks.</li><li>Uses curated browser-side preset data for quick local generation.</li></ul><div class="tool-points"><span class="tool-point"><i class="fa-solid fa-code"></i>Powered by curated browser-side presets</span></div></div></div></div></Content></Layout><script type="module" src={pageScript}></script>
